---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-top">
    <div class="container footer-top-inner">
      <div class="footer-brand">
        <span class="brand-name">Muheeb Hashimi</span>
        <span class="brand-tagline">Accounting &amp; Tax Services</span>
        <p class="footer-blurb">
          Professional tax and accounting services for individuals and businesses 
          in Montréal and across Québec. Filing done right — every time.
        </p>
      </div>

      <div class="footer-col">
        <span class="footer-col-title">Services</span>
        <ul>
          <li><a href="#services">Personal Tax Returns</a></li>
          <li><a href="#services">Corporate Tax Returns</a></li>
          <li><a href="#services">Bookkeeping</a></li>
          <li><a href="#services">GST / HST / QST</a></li>
          <li><a href="#services">Financial Consulting</a></li>
          <li><a href="#services">CRA Correspondence</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <span class="footer-col-title">Quick Links</span>
        <ul>
          <li><a href="#home">Home</a></li>
          <li><a href="#about">About</a></li>
          <li><a href="#contact">Contact</a></li>
        </ul>

        <span class="footer-col-title" style="margin-top: 28px;">Location</span>
        <p class="footer-location">
          Montréal, Québec<br />
          Canada<br />
          <span class="footer-lang">English · Français</span>
        </p>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <p class="footer-copy">
        &copy; {year} Muheeb Hashimi. All rights reserved.
      </p>
      <p class="footer-disclaimer">
        This website is for informational purposes only and does not constitute professional financial advice.
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--navy);
    border-top: 1px solid rgba(198, 151, 63, 0.15);
  }

  .footer-top {
    padding: 72px 24px 56px;
  }

  .footer-top-inner {
    display: grid;
    grid-template-columns: 2fr 1.2fr 1.2fr;
    gap: 60px;
  }

  .brand-name {
    display: block;
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--cream);
    letter-spacing: 0.02em;
    margin-bottom: 4px;
  }

  .brand-tagline {
    display: block;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 20px;
  }

  .footer-blurb {
    font-size: 0.875rem;
    color: rgba(247, 244, 238, 0.45);
    line-height: 1.8;
    max-width: 320px;
  }

  .footer-col-title {
    display: block;
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 16px;
  }

  .footer-col ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer-col ul a {
    font-size: 0.875rem;
    color: rgba(247, 244, 238, 0.55);
    transition: color 0.25s ease;
  }

  .footer-col ul a:hover {
    color: var(--gold-light);
  }

  .footer-location {
    font-size: 0.875rem;
    color: rgba(247, 244, 238, 0.55);
    line-height: 1.8;
  }

  .footer-lang {
    display: inline-block;
    margin-top: 4px;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.1em;
    color: var(--gold);
  }

  /* Bottom bar */
  .footer-bottom {
    border-top: 1px solid rgba(247, 244, 238, 0.06);
    padding: 20px 24px;
  }

  .footer-bottom-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
  }

  .footer-copy {
    font-size: 11px;
    color: rgba(247, 244, 238, 0.3);
    letter-spacing: 0.05em;
  }

  .footer-disclaimer {
    font-size: 10px;
    color: rgba(247, 244, 238, 0.2);
    text-align: right;
    max-width: 440px;
  }

  @media (max-width: 840px) {
    .footer-top-inner {
      grid-template-columns: 1fr 1fr;
      gap: 40px;
    }
    .footer-brand { grid-column: 1 / -1; }
  }

  @media (max-width: 520px) {
    .footer-top-inner { grid-template-columns: 1fr; }
    .footer-bottom-inner { flex-direction: column; align-items: flex-start; }
    .footer-disclaimer { text-align: left; }
  }
</style>
